{
  "name": "data-descriptions-transforms-monorepo",
  "private": true,
  "version": "0.0.0-development",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EngraphCode/castr.git"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "type-check": "turbo type-check",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "test": "turbo test",
    "test:watch": "turbo test -- --watch",
    "test:coverage": "turbo test -- --coverage",
    "agent-tools:test": "pnpm --filter @engraph/agent-tools test",
    "agent-tools": "pnpm --filter @engraph/agent-tools agent-tools",
    "agent-tools:build": "pnpm --filter @engraph/agent-tools build",
    "agent-tools:agent-identity": "pnpm --filter @engraph/agent-tools agent-identity",
    "agent-tools:collaboration-state": "pnpm --filter @engraph/agent-tools collaboration-state",
    "agent-tools:claude-agent-ops": "pnpm --filter @engraph/agent-tools claude-agent-ops",
    "agent-tools:commit-queue": "pnpm --filter @engraph/agent-tools commit-queue",
    "agent-tools:branch-touched-files": "pnpm --filter @engraph/agent-tools branch-touched-files",
    "agent-tools:context-cost": "pnpm --filter @engraph/agent-tools context-cost",
    "agent-tools:check-commit-message": "pnpm --filter @engraph/agent-tools check-commit-message",
    "agent-tools:check-commit-skill-advisories": "pnpm --filter @engraph/agent-tools check-commit-skill-advisories",
    "agent-tools:repo-check": "pnpm --filter @engraph/agent-tools repo-check",
    "check:profile": "pnpm agent-tools:repo-check profile",
    "agent-tools:lint": "pnpm --filter @engraph/agent-tools lint",
    "agent-tools:prevent-accidental-major-version": "pnpm --filter @engraph/agent-tools prevent-accidental-major-version",
    "agent-tools:check-blocked-content": "pnpm --filter @engraph/agent-tools check-blocked-content",
    "agent-tools:check-blocked-patterns": "pnpm --filter @engraph/agent-tools check-blocked-patterns",
    "agent-tools:codex-exec": "pnpm --filter @engraph/agent-tools codex-exec",
    "agent-tools:codex-reviewer-resolve": "pnpm --filter @engraph/agent-tools codex-reviewer-resolve",
    "agent-tools:cursor-session-from-claude-session": "pnpm --filter @engraph/agent-tools cursor-session-from-claude-session",
    "practice:substrate:check": "pnpm --filter @engraph/agent-tools practice-substrate -- check",
    "practice:fitness": "pnpm --filter @engraph/agent-tools validate-practice-fitness",
    "practice:fitness:informational": "pnpm --filter @engraph/agent-tools validate-practice-fitness -- --informational",
    "practice:fitness:strict-hard": "pnpm --filter @engraph/agent-tools validate-practice-fitness -- --strict-hard",
    "practice:vocabulary": "pnpm --filter @engraph/agent-tools validate-fitness-vocabulary",
    "test:snapshot": "turbo test:snapshot",
    "test:gen": "turbo test:gen",
    "character": "turbo character",
    "test:transforms": "turbo test:transforms",
    "test:e2e": "turbo test:e2e",
    "madge:circular": "turbo madge:circular",
    "madge:orphans": "turbo madge:orphans",
    "depcruise": "turbo depcruise",
    "knip": "turbo knip",
    "markdownlint-check:root": "markdownlint-cli2",
    "markdownlint:root": "markdownlint-cli2 --fix",
    "secrets:scan": "GIT_CONFIG_COUNT=1 GIT_CONFIG_KEY_0=diff.renameLimit GIT_CONFIG_VALUE_0=3000 gitleaks detect --redact=100 --source . --log-opts=\"--branches --tags\"",
    "secrets:scan:all": "GIT_CONFIG_COUNT=1 GIT_CONFIG_KEY_0=diff.renameLimit GIT_CONFIG_VALUE_0=3000 gitleaks detect --redact=100 --source . --log-opts=\"--branches --tags --full-history\"",
    "secrets:scan:all-refs": "GIT_CONFIG_COUNT=1 GIT_CONFIG_KEY_0=diff.renameLimit GIT_CONFIG_VALUE_0=3000 gitleaks detect --redact=100 --source . --log-opts=\"--all --full-history\"",
    "portability:check": "pnpm --filter @engraph/agent-tools validate-portability",
    "skills:check": "pnpm --filter @engraph/agent-tools -s build && node agent-tools/dist/src/bin/skills-adapter-generate.js --check --prefix=engraph-",
    "agents:adapter-generate": "pnpm --filter @engraph/agent-tools -s build && node agent-tools/dist/src/bin/agent-adapter-generate.js",
    "agents:check": "pnpm --filter @engraph/agent-tools -s build && node agent-tools/dist/src/bin/agent-adapter-generate.js --check",
    "repo-validators:check": "pnpm --filter @engraph/agent-tools validate-lifecycle-scripts && pnpm --filter @engraph/agent-tools validate-pretooluse-guard-routing && pnpm --filter @engraph/agent-tools validate-drift && pnpm --filter @engraph/agent-tools validate-fitness-vocabulary && pnpm --filter @engraph/agent-tools validate-no-stale-script-invocations && pnpm --filter @engraph/agent-tools validate-loop-closure-references && pnpm --filter @engraph/agent-tools validate-no-machine-local-paths && pnpm --filter @engraph/agent-tools validate-reference-direction && pnpm --filter @engraph/agent-tools validate-patterns-index && pnpm --filter @engraph/agent-tools validate-subagents && pnpm --filter @engraph/agent-tools validate-collaboration-state && pnpm --filter @engraph/agent-tools validate-policy-reappraisal",
    "packaging:check": "pnpm --filter @engraph/castr packaging:check",
    "test:all": "pnpm test && pnpm character && pnpm test:snapshot && pnpm test:gen && pnpm test:transforms && pnpm test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "clean": "turbo clean",
    "fix": "pnpm format && pnpm lint:fix",
    "qg": "pnpm secrets:scan && pnpm build && pnpm format:check && pnpm type-check && pnpm lint && pnpm madge:circular && pnpm madge:orphans && pnpm depcruise && pnpm knip && pnpm markdownlint-check:root && pnpm portability:check && pnpm packaging:check && pnpm skills:check && pnpm agents:check && pnpm repo-validators:check && pnpm test:all",
    "check": "pnpm clean && pnpm install --frozen-lockfile && pnpm fix && pnpm qg",
    "check:ci": "pnpm clean && pnpm install --frozen-lockfile && pnpm qg",
    "fetch:examples": "turbo fetch:examples",
    "postinstall": "tsx agent-tools/src/bootstrap/bootstrap.ts",
    "prepare": "husky"
  },
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@typescript-eslint/rule-tester": "^8.62.1",
    "@typescript-eslint/utils": "^8.62.1",
    "ajv": "^8.18.0",
    "ajv-draft-04": "^1.0.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-pretty": "^7.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.1.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "madge": "^8.0.0",
    "markdownlint-cli2": "^0.23.0",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "turbo": "^2.10.2",
    "typescript": "^6",
    "typescript-eslint": "^8.62.1"
  }
}
