{
  "name": "data-descriptions-transforms-monorepo",
  "private": true,
  "version": "0.0.0-development",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EngraphCode/castr.git"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "type-check": "turbo type-check",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "test": "turbo test --filter=!@engraph/agent-tools",
    "test:watch": "turbo test -- --watch",
    "agent-tools:test:informational": "pnpm --filter @engraph/agent-tools test",
    "agent-tools": "pnpm --filter @engraph/agent-tools agent-tools",
    "agent-tools:build": "pnpm --filter @engraph/agent-tools build",
    "agent-tools:agent-identity": "pnpm --filter @engraph/agent-tools agent-identity",
    "agent-tools:collaboration-state": "pnpm --filter @engraph/agent-tools collaboration-state",
    "agent-tools:claude-agent-ops": "pnpm --filter @engraph/agent-tools claude-agent-ops",
    "agent-tools:commit-queue": "pnpm --filter @engraph/agent-tools commit-queue",
    "agent-tools:branch-touched-files": "pnpm --filter @engraph/agent-tools branch-touched-files",
    "agent-tools:context-cost": "pnpm --filter @engraph/agent-tools context-cost",
    "test:snapshot": "turbo test:snapshot",
    "test:gen": "turbo test:gen",
    "character": "turbo character",
    "test:transforms": "turbo test:transforms",
    "test:e2e": "turbo test:e2e",
    "madge:circular": "turbo madge:circular",
    "madge:orphans": "turbo madge:orphans",
    "depcruise": "turbo depcruise",
    "knip": "turbo knip",
    "portability:check": "node scripts/validate-portability.mjs",
    "skills:check": "pnpm --filter @engraph/agent-tools -s build && node agent-tools/dist/src/bin/skills-adapter-generate.js --check --prefix=engraph-",
    "repo-validators:check": "pnpm --filter @engraph/agent-tools validate-lifecycle-scripts && pnpm --filter @engraph/agent-tools validate-pretooluse-guard-routing && pnpm --filter @engraph/agent-tools validate-drift && pnpm --filter @engraph/agent-tools validate-fitness-vocabulary && pnpm --filter @engraph/agent-tools validate-no-stale-script-invocations",
    "packaging:check": "pnpm --filter @engraph/castr packaging:check",
    "test:all": "pnpm test && pnpm character && pnpm test:snapshot && pnpm test:gen && pnpm test:transforms && pnpm test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "clean": "turbo clean",
    "fix": "pnpm format && pnpm lint:fix",
    "qg": "pnpm build && pnpm format:check && pnpm type-check && pnpm lint && pnpm madge:circular && pnpm madge:orphans && pnpm depcruise && pnpm knip && pnpm portability:check && pnpm packaging:check && pnpm skills:check && pnpm repo-validators:check && pnpm test:all",
    "check": "pnpm clean && pnpm install --frozen-lockfile && pnpm fix && pnpm qg",
    "check:ci": "pnpm clean && pnpm install --frozen-lockfile && pnpm qg",
    "fetch:examples": "turbo fetch:examples",
    "postinstall": "tsx agent-tools/src/bootstrap/bootstrap.ts",
    "prepare": "husky"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@typescript-eslint/rule-tester": "^8.58.0",
    "@typescript-eslint/utils": "^8.58.0",
    "ajv": "^8.18.0",
    "ajv-draft-04": "^1.0.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-pretty": "^7.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "turbo": "^2.9.17",
    "typescript": "^5",
    "typescript-eslint": "^8.58.0"
  }
}
