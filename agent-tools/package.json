{
  "name": "@engraph/agent-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript tooling workspace for agent operational CLIs",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/src/bin/*.js dist/src/claude/statusline-identity.js",
    "clean": "rm -rf dist .turbo",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "smoke:collaboration-tui": "tsx smoke-tests/collaboration-tui-start.smoke.ts",
    "type-check": "tsc -p tsconfig.json",
    "agent-tools": "cd .. && node agent-tools/dist/src/bin/agent-tools.js",
    "agent-identity": "cd .. && node agent-tools/dist/src/bin/agent-tools.js agent-identity",
    "collaboration-state": "cd .. && node agent-tools/dist/src/bin/agent-tools.js collaboration-state",
    "practice-substrate": "pnpm -s build && cd .. && node agent-tools/dist/src/bin/practice-substrate.js",
    "branch-touched-files": "cd .. && node agent-tools/dist/src/bin/agent-tools.js branch-touched-files",
    "context-cost": "cd .. && node agent-tools/dist/src/bin/agent-tools.js context-cost",
    "codex-session-identity-hook": "pnpm -s build && node dist/src/bin/codex-session-identity-hook.js",
    "claude-agent-ops": "tsx src/bin/claude-agent-ops.ts",
    "commit-queue": "cd .. && node agent-tools/dist/src/bin/agent-tools.js commit-queue",
    "codex-exec": "cd .. && node agent-tools/dist/src/bin/agent-tools.js codex-exec",
    "cursor-session-from-claude-session": "tsx src/bin/cursor-session-from-claude-session.ts",
    "codex-reviewer-resolve": "tsx src/bin/codex-reviewer-resolve.ts",
    "skills-adapter-generate": "tsx src/bin/skills-adapter-generate.ts",
    "repo-check": "cd .. && pnpm exec tsx agent-tools/src/repo-check/repo-check.ts",
    "check-blocked-patterns": "cd .. && pnpm exec tsx agent-tools/src/hook-policy/check-blocked-patterns.ts",
    "check-blocked-content": "cd .. && pnpm exec tsx agent-tools/src/hook-policy/check-blocked-content.ts",
    "check-commit-message": "cd .. && pnpm exec tsx agent-tools/src/commit-advisories/check-commit-message.ts",
    "check-commit-skill-advisories": "cd .. && pnpm exec tsx agent-tools/src/commit-advisories/check-commit-skill-advisories.ts",
    "prevent-accidental-major-version": "cd .. && pnpm exec tsx agent-tools/src/version-guard/prevent-accidental-major-version.ts",
    "validate-fitness-vocabulary": "cd .. && pnpm exec tsx agent-tools/src/validators/fitness-vocabulary/validate-fitness-vocabulary.ts",
    "validate-collaboration-state": "cd .. && pnpm exec tsx agent-tools/src/validators/collaboration-state/validate-collaboration-state.ts",
    "validate-no-stale-script-invocations": "cd .. && pnpm exec tsx agent-tools/src/validators/stale-script-invocations/validate-no-stale-script-invocations.ts",
    "validate-lifecycle-scripts": "cd .. && pnpm exec tsx agent-tools/src/validators/lifecycle-scripts/validate-lifecycle-scripts.ts",
    "validate-pretooluse-guard-routing": "cd .. && pnpm exec tsx agent-tools/src/validators/pretooluse-guard-routing/validate-pretooluse-guard-routing.ts",
    "validate-policy-reappraisal": "cd .. && pnpm exec tsx agent-tools/src/validators/policy-reappraisal/validate-policy-reappraisal.ts",
    "validate-portability": "cd .. && pnpm exec tsx agent-tools/src/validators/portability/validate-portability.ts",
    "validate-portability:fix": "cd .. && pnpm exec tsx agent-tools/src/validators/portability/validate-portability.ts --fix",
    "validate-practice-fitness": "cd .. && pnpm exec tsx agent-tools/src/practice-fitness/validate-practice-fitness.ts",
    "validate-subagents": "cd .. && pnpm exec tsx agent-tools/src/validators/subagents/validate-subagents.ts",
    "validate-drift": "cd .. && pnpm exec tsx agent-tools/src/validators/drift/validate-drift.ts",
    "validate-patterns-index": "cd .. && pnpm exec tsx agent-tools/src/validators/patterns-index/validate-patterns-index.ts",
    "validate-patterns-index:fix": "cd .. && pnpm exec tsx agent-tools/src/validators/patterns-index/validate-patterns-index.ts --fix",
    "ci-turbo-report": "cd .. && pnpm exec tsx agent-tools/src/ci/ci-turbo-report.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.15",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "ink-testing-library": "^4.0.0",
    "jiti": "^2.6.1",
    "knip": "^6.17.1",
    "tsx": "^4.22.4",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ink": "^7.0.5",
    "react": "^19.2.6",
    "tinyglobby": "^0.2.17",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
