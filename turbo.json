{
  "$schema": "https://v2-10-2.turborepo.dev/schema.json",
  "globalDependencies": ["tsconfig.json", ".prettierrc.json", ".prettierignore"],
  "ui": "stream",
  "tasks": {
    "clean": {
      "cache": false,
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "out/**"]
    },
    "type-check": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": ["coverage/**"]
    },
    "@engraph/agent-tools#test": {
      "cache": false,
      "outputs": ["coverage/**"]
    },
    "test:snapshot": {
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/.agent/reference/openapi_schema/**"],
      "outputs": []
    },
    "test:gen": {
      "outputs": []
    },
    "character": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:transforms": {
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "madge:circular": {
      "outputs": []
    },
    "madge:orphans": {
      "outputs": []
    },
    "depcruise": {
      "outputs": []
    },
    "knip": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "fetch:examples": {
      "cache": false,
      "outputs": []
    }
  }
}
