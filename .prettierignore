# Repo specific
**/reference/**/*
lib/examples
tmp/

# Machine-local, harness-written or harness-managed — never repo content.
# Worktrees hold full in-progress checkouts; sweeping them makes every gate
# run hostage to concurrent agents' intermediate file states.
.claude/worktrees/
.claude/settings.local.json

# Dependencies
node_modules
.pnpm-store

# Build outputs
dist
build
.next
out
.turbo

# Templates (Handlebars syntax not compatible with Prettier)
*.hbs

# Generated files
pnpm-lock.yaml
CHANGELOG.md

# Test snapshots
**/__snapshots__/**

# Cache
.eslintcache

# Live ARC channel files — append-only while tailed; a format --fix rewrite
# replays every follower's tail (see .agent/reference/arc-rapid-communication.md
# §Known limitations). A channel is ANY non-README markdown file at ANY depth
# under rapid-comms (the `isArcChannelFileName` convention: nested channels are
# first-class — recursive readdir in the statusline gatherer, nested paths in
# the gate). The convention READMEs stay formatted via the re-include.
.agent/collaboration/rapid-comms/**/*.md
!.agent/collaboration/rapid-comms/**/README.md

# Instance-tier collaboration state — regenerated at runtime, gitignored.
# Mirrors .agent/state/collaboration/.gitignore so the format gate does not
# trip on runtime-written JSON/log files (e.g. a claim opened with a
# multi-area patterns array). Tracked READMEs/.gitkeep stay checked.
.agent/state/collaboration/active-claims.json
.agent/state/collaboration/closed-claims.archive.json
.agent/state/collaboration/shared-comms-log.md
.agent/state/collaboration/comms/
.agent/state/collaboration/comms-seen/
.agent/state/collaboration/comms-draft/

