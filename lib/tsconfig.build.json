{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "**/*.typegen.ts",
    "example",
    "tests",
    "dist",
    "src/**/*.test.ts",
    "src/**/__tests__/**",
    "src/characterisation/**"
  ]
}
