{
  "name": "@engraph/castr",
  "version": "1.18.3",
  "description": "Transform schemas between formats using a canonical internal representation. OpenAPI, Zod, TypeScript, JSON Schema, and MCP tools.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jimcresswell/openapi-zod-validation.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./parsers/zod": {
      "types": "./dist/parsers/zod/index.d.ts",
      "import": "./dist/parsers/zod/index.js"
    }
  },
  "homepage": "https://github.com/jimcresswell/openapi-zod-validation",
  "bin": {
    "castr": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "clean": "rimraf dist && rimraf tsconfig.tsbuildinfo",
    "dev": "tsup --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit --project tsconfig.lint.json",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-location .eslintcache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:snapshot": "vitest run --config vitest.snapshot.config.ts",
    "test:snapshot:watch": "vitest --config vitest.snapshot.config.ts",
    "test:gen": "vitest run --config vitest.generated.config.ts",
    "test:gen:watch": "vitest --config vitest.generated.config.ts",
    "test:scalar-guard": "vitest run --config vitest.scalar-guard.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "character": "vitest run --config vitest.characterisation.config.ts",
    "character:watch": "vitest --config vitest.characterisation.config.ts",
    "test:transforms": "vitest run --config vitest.transforms.config.ts",
    "doctor:profile": "pnpm exec tsx ./scripts/profile-doctor-runtime.mts",
    "madge:circular": "node ./scripts/run-madge.mjs circular",
    "madge:orphans": "node ./scripts/run-madge.mjs orphans",
    "depcruise": "pnpm exec depcruise src --config .dependency-cruiser.cjs",
    "knip": "pnpm exec knip",
    "fetch:examples": "tsx ./examples-fetcher.mts"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scalar/json-magic": "0.12.4",
    "@scalar/openapi-parser": "0.25.7",
    "@scalar/openapi-types": "0.6.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.3",
    "lodash-es": "^4.18.1",
    "openapi3-ts": "^4.5.0",
    "prettier": "^3.8.1",
    "ts-morph": "^27.0.2",
    "ts-pattern": "^5.9.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "openapi-fetch": "^0.15.0"
  },
  "peerDependenciesMeta": {
    "openapi-fetch": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/degit": "^2.8.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.2",
    "@typescript-eslint/parser": "^8.58.0",
    "degit": "^2.8.4",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.1.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "fast-glob": "^3.3.3",
    "globals": "^17.4.0",
    "knip": "^6.3.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "keywords": [
    "openapi",
    "swagger",
    "zod",
    "client",
    "generator",
    "typescript",
    "validation",
    "schema",
    "mcp",
    "castr"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
