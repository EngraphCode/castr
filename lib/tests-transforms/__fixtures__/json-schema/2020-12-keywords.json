{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "TupleSchema": {
      "type": "array",
      "prefixItems": [{ "type": "string" }, { "type": "integer" }, { "type": "boolean" }]
    },
    "ConstValue": {
      "const": "fixed-value"
    },
    "DependentRequiredSchema": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "creditCard": { "type": "string" },
        "billingAddress": { "type": "string" }
      },
      "dependentRequired": {
        "creditCard": ["billingAddress"]
      }
    },
    "DependentSchemasExample": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" }
      },
      "dependentSchemas": {
        "role": {
          "properties": {
            "department": { "type": "string" }
          },
          "required": ["department"]
        }
      }
    },
    "StrictObject": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      },
      "unevaluatedProperties": false
    },
    "PatternPropertiesSchema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" }
      },
      "patternProperties": {
        "^x-": { "type": "string" },
        "^i-": { "type": "integer" }
      }
    },
    "PropertyNamesSchema": {
      "type": "object",
      "additionalProperties": false,
      "propertyNames": {
        "type": "string",
        "minLength": 2,
        "maxLength": 50,
        "pattern": "^[a-z]"
      }
    },
    "ContainsSchema": {
      "type": "array",
      "contains": { "type": "string", "minLength": 1 }
    },
    "ConditionalApplicatorSchema": {
      "type": "object",
      "properties": {
        "kind": { "type": "string" }
      },
      "if": {
        "properties": {
          "kind": { "const": "business" }
        }
      },
      "then": {
        "properties": {
          "taxId": { "type": "string" }
        },
        "required": ["taxId"]
      },
      "else": {
        "properties": {
          "firstName": { "type": "string" }
        },
        "required": ["firstName"]
      }
    },
    "AnchorSchema": {
      "type": "object",
      "$anchor": "address",
      "properties": {
        "street": { "type": "string" }
      }
    },
    "DynamicRefSchema": {
      "type": "object",
      "$dynamicRef": "#node",
      "properties": {
        "value": { "type": "string" }
      }
    },
    "DynamicAnchorSchema": {
      "type": "object",
      "$dynamicAnchor": "node",
      "properties": {
        "children": { "type": "array" }
      }
    }
  }
}
